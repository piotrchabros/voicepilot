# Copy to .env and fill in what you need — every key here is optional.
# Validated fail-fast by src/main/env.ts (zod). Unknown keys are ignored.

# Soniox cloud STT API key (Plans.md 1.2). Omit to use the local engine only.
SONIOX_API_KEY=

# Soniox WS endpoint override. Must be wss://; the EU-host allowlist
# (spec.md §4.1) is enforced separately at boot via assertEuEndpoint.
SONIOX_WS_URL=

# Debug flags — each is '0' or '1'.
COPILOT_DEBUG=
COPILOT_DEMO=
COPILOT_NO_PROTECT=
COPILOT_PLACEHOLDER=
COPILOT_MIC_SPECULATE=

# Transport-B consent announcement script (spec.md §4 item 2, Plans.md Task
# 4.1). This wording is a legal deliverable (docs/compliance.md item 4) —
# never invent it here. Leave unset until legal review lands; the overlay
# then shows a clearly-marked placeholder and refuses to be mistaken for the
# real announcement.
CONSENT_ANNOUNCEMENT_PL=
