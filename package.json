{
  "name": "copilot",
  "version": "0.1.0",
  "description": "Live conversation copilot — Electron port (macOS only)",
  "private": true,
  "author": "Bespokesoft",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "app": "electron-vite build && electron .",
    "list-devices": "electron-vite build && electron . --list-devices",
    "bench": "electron-vite build && electron . --bench",
    "ttft": "electron-vite build && electron . --ttft",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format . --write",
    "format:check": "biome format .",
    "sidecar": "swift build --package-path native/capture -c release"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "onnxruntime-node": "1.19.2",
    "sherpa-onnx-node": "^1.10.30",
    "ws": "^8.21.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^22.7.4",
    "@types/ws": "^8.18.1",
    "electron": "^33.0.0",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
